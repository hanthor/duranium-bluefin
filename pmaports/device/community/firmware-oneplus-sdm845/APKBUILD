maintainer="Casey Connolly <kcxt@postmarketos.org>"
pkgname=firmware-oneplus-sdm845
pkgver=13
pkgrel=0
_commit="176ca713448c5237a983fb1f158cf3a5c251d775"
pkgdesc="Firmware for OnePlus 6 / 6T"
url="https://gitlab.com/sdm845-mainline/firmware-oneplus-sdm845"
arch="aarch64"
depends="linux-firmware-qcom linux-firmware-ath10k"
license="proprietary"
subpackages="
	$pkgname-pmtest
	$pkgname-sensors:firmware_sensors
	"
source="$pkgname-$_commit.tar.gz::https://gitlab.com/sdm845-mainline/firmware-oneplus-sdm845/-/archive/$_commit/$pkgname-$_commit.tar.gz
	firmware.files
	sensor.files
	30-oneplus-sdm845-firmware-ci.files
	0001-oneplus6-set-mount-matrix.patch
	"
options="!archcheck !check !strip !tracedeps pmb:cross-native textrels"
builddir="$srcdir/$pkgname-$_commit"

package() {
	while IFS="" read -r _i || [ -n "$_i" ]; do
		local _u="${_i/usr\/lib/\/lib}"
		[ ! -d $(dirname $_i) ] && mkdir -p $(dirname "$pkgdir"/$_i)
		install -Dm644 .$_u "$pkgdir/$_i"
	done < "$srcdir/firmware.files"
}

pmtest() {
	install_if="$pkgname=$pkgver-r$pkgrel postmarketos-mkinitfs-hook-ci"

	install -Dm644 "$srcdir/30-oneplus-sdm845-firmware-ci.files" \
		"$subpkgdir/usr/share/mkinitfs/files/30-oneplus-sdm845-firmware-ci.files"
}

firmware_sensors() {
	pkgdesc="Files to be included to add sensor support"
	depends="$pkgname"
	install_if="$pkgname-nonfree-firmware"
	mkdir "$subpkgdir"

	cd "$builddir"
	while IFS="" read -r _i || [ -n "$_i" ]; do
		local _u="${_i/usr\/lib/\/lib}"
		[ ! -d $(dirname $_i) ] && mkdir -p $(dirname "$subpkgdir"/$_i)
		install -Dm644 .$_u "$subpkgdir/$_i"
	done < "$srcdir/sensor.files"

	ln -s oneplus6 "$subpkgdir"/usr/share/qcom/sdm845/OnePlus/enchilada
	ln -s oneplus6 "$subpkgdir"/usr/share/qcom/sdm845/OnePlus/fajita
}

