From 02442ef84c908c169417d90a8440ae6feb1cc20d Mon Sep 17 00:00:00 2001
From: Andreas Kemnade <andreas@kemnade.info>
Date: Wed, 6 May 2026 12:50:14 +0200
Subject: [PATCH] another CFI fix

Signed-off-by: Andreas Kemnade <andreas@kemnade.info>
---
 include/osdep_service_linux.h | 4 ++--
 include/xmit_osdep.h          | 4 ++--
 os_dep/linux/ioctl_cfg80211.c | 2 +-
 os_dep/linux/mlme_linux.c     | 2 +-
 os_dep/linux/xmit_linux.c     | 4 ++--
 5 files changed, 8 insertions(+), 8 deletions(-)

diff --git a/include/xmit_osdep.h b/include/xmit_osdep.h
index e6f6f28..544c5bc 100644
--- a/include/xmit_osdep.h
+++ b/include/xmit_osdep.h
@@ -67,8 +67,8 @@ struct sta_xmit_priv;
 struct xmit_frame;
 struct xmit_buf;
 
-extern int _rtw_xmit_entry(_pkt *pkt, _nic_hdl pnetdev);
-extern int rtw_xmit_entry(_pkt *pkt, _nic_hdl pnetdev);
+extern netdev_tx_t _rtw_xmit_entry(_pkt *pkt, _nic_hdl pnetdev);
+extern netdev_tx_t rtw_xmit_entry(_pkt *pkt, _nic_hdl pnetdev);
 
 #endif /* PLATFORM_LINUX */
 
diff --git a/os_dep/linux/ioctl_cfg80211.c b/os_dep/linux/ioctl_cfg80211.c
index c2f8398..6696298 100644
--- a/os_dep/linux/ioctl_cfg80211.c
+++ b/os_dep/linux/ioctl_cfg80211.c
@@ -4382,7 +4382,7 @@ static int rtw_cfg80211_monitor_if_close(struct net_device *ndev)
 	return ret;
 }
 
-static int rtw_cfg80211_monitor_if_xmit_entry(struct sk_buff *skb, struct net_device *ndev)
+static netdev_tx_t rtw_cfg80211_monitor_if_xmit_entry(struct sk_buff *skb, struct net_device *ndev)
 {
 	int ret = 0;
 	int rtap_len;
diff --git a/os_dep/linux/mlme_linux.c b/os_dep/linux/mlme_linux.c
index 39c0ac1..49e9c17 100644
--- a/os_dep/linux/mlme_linux.c
+++ b/os_dep/linux/mlme_linux.c
@@ -278,7 +278,7 @@ void rtw_indicate_sta_disassoc_event(_adapter *padapter, struct sta_info *psta)
 
 #ifdef CONFIG_HOSTAPD_MLME
 
-static int mgnt_xmit_entry(struct sk_buff *skb, struct net_device *pnetdev)
+static netdev_tx_t mgnt_xmit_entry(struct sk_buff *skb, struct net_device *pnetdev)
 {
 	struct hostapd_priv *phostapdpriv = rtw_netdev_priv(pnetdev);
 	_adapter *padapter = (_adapter *)phostapdpriv->padapter;
diff --git a/os_dep/linux/xmit_linux.c b/os_dep/linux/xmit_linux.c
index 3c42eb5..622a66a 100644
--- a/os_dep/linux/xmit_linux.c
+++ b/os_dep/linux/xmit_linux.c
@@ -451,7 +451,7 @@ int rtw_mlcst2unicst(_adapter *padapter, struct sk_buff *skb)
 #endif /* CONFIG_TX_MCAST2UNI */
 
 
-int _rtw_xmit_entry(_pkt *pkt, _nic_hdl pnetdev)
+netdev_tx_t _rtw_xmit_entry(_pkt *pkt, _nic_hdl pnetdev)
 {
 	_adapter *padapter = (_adapter *)rtw_netdev_priv(pnetdev);
 	struct xmit_priv *pxmitpriv = &padapter->xmitpriv;
@@ -551,7 +551,7 @@ exit:
 	return 0;
 }
 
-int rtw_xmit_entry(_pkt *pkt, _nic_hdl pnetdev)
+netdev_tx_t rtw_xmit_entry(_pkt *pkt, _nic_hdl pnetdev)
 {
 	_adapter *padapter = (_adapter *)rtw_netdev_priv(pnetdev);
 	struct	mlme_priv	*pmlmepriv = &(padapter->mlmepriv);
-- 
2.47.3

