pkgname=device-fairphone-fp6
pkgdesc="The Fairphone (Gen. 6)"
pkgver=6
pkgrel=2
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	firmware-fairphone-fp6-adreno
	firmware-fairphone-fp6-adsp
	firmware-fairphone-fp6-bluetooth
	firmware-fairphone-fp6-cdsp
	firmware-fairphone-fp6-ipa
	firmware-fairphone-fp6-modem
	firmware-fairphone-fp6-vpu
	firmware-fairphone-fp6-wpss
	linux-firmware-ath11k
	linux-postmarketos-qcom-milos
	make-dynpart-mappings
	mkbootimg
	postmarketos-base
	soc-qcom
	soc-qcom-modem
	soc-qcom-qbootctl
"
makedepends="devicepkg-dev"
source="
	deviceinfo
	kernel-cmdline.conf
	modules-initfs
	sim-wait-time.conf
	"
subpackages="$pkgname-systemd"
build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname

	install -Dm644 "$srcdir"/sim-wait-time.conf \
		"$pkgdir"/usr/lib/systemd/system/msm-modem-uim-selection.service.d/sim-wait-time.conf
}

