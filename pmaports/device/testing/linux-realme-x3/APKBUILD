a8abea661d686a3a27b1294749dc151194a4c5ec469e481fdc10519323baa972da59e3701195214b35d262a583164fee1926738f7ca5d4709bcd767623c4c462  config-realme-x3.aarch64
1b15a999007ea399814bd8be23bc3d3ab9c8602e145f8b016f0c84a613d5c48f7b319124ef11514927277b670ba4beeb43d375836f8bf1bb97dcc4479c54338d  disable-builtin-wcslen.patch
