[Transfer]
ProtectVersion=%A

[Source]
Type=url-file
Path=https://duranium.postmarketos.org/images/%M_%W_%w/
MatchPattern=%M_%W_%w_@v.usr-%a.@u.raw.zst

[Target]
Type=partition
Path=auto
MatchPattern=duranium_@v_usr
# TODO: drop this after some time
MatchPattern=%M_@v_usr
MatchPartitionType=usr
PartitionFlags=0
ReadOnly=1
