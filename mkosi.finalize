#!/bin/sh
set -e

# mkosi can't preserve setgid shadow when running unprivileged, so we "fix" this
# by setuid root and in the initramfs set perms to 0. This mimmicks that Fedora
# does...
chmod 4755 "$BUILDROOT/usr/sbin/unix_chkpwd"

# Update os-release
sed -i "s/^HOME_URL=.*/HOME_URL=https:\/\/github.com\/hanthor\/duranium-bluefin/" "$BUILDROOT/usr/lib/os-release"
echo "LOGO=gnome" >> "$BUILDROOT/usr/lib/os-release"

echo "Finalize complete!"
