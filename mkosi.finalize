#!/bin/sh
set -e

# mkosi can't preserve setgid shadow when running unprivileged, so we "fix" this
# by setuid root and in the initramfs set perms to 0. This mimmicks that Fedora
# does...
chmod 4755 "$BUILDROOT/usr/sbin/unix_chkpwd"

## Fixup os-release
# Fix IMAGE_ID to be device-only (not device_ui_release)
sed -i "s/^IMAGE_ID=.*/IMAGE_ID=$PMOS_DEVICE/" "$BUILDROOT/usr/lib/os-release"
# Add VARIANT_ID for UI
echo "VARIANT_ID=$PMOS_VARIANT" >> "$BUILDROOT/usr/lib/os-release"
# Ensure confexts are only merged when they match the running OS version.
echo "CONFEXT_LEVEL=$IMAGE_VERSION" >> "$BUILDROOT/usr/lib/os-release"
# Ensure sysexts are only merged when they match the running OS version.
echo "SYSEXT_LEVEL=$IMAGE_VERSION" >> "$BUILDROOT/usr/lib/os-release"

# Add pmOS pub key for sysupdate manifest verify to systemd keyring
# FIXME: this key is not secure!
gpg --no-default-keyring \
   --keyring "$BUILDROOT"/usr/lib/systemd/import-pubring.pgp \
   --import pmos-sysupdate-public-key.asc

# Generate sysusers.d and tmpfiles.d config for Alpine system users
mkdir -p "$BUILDROOT/usr/lib/sysusers.d" "$BUILDROOT/usr/lib/tmpfiles.d"

SYSUSERS_OUT="$BUILDROOT/usr/lib/sysusers.d/alpine-compat.conf"
TMPFILES_OUT="$BUILDROOT/usr/lib/tmpfiles.d/alpine-compat.conf"

# Build skip sets from existing sysusers.d snippets
SKIP_USERS=$(awk '/^u/ {print $2}' "$BUILDROOT"/usr/lib/sysusers.d/*.conf 2>/dev/null)
SKIP_GROUPS=$(awk '/^[ug]/ {print $2}' "$BUILDROOT"/usr/lib/sysusers.d/*.conf 2>/dev/null)
SKIP_MEMBERS=$(awk '/^m/ {print $2":"$3}' "$BUILDROOT"/usr/lib/sysusers.d/*.conf 2>/dev/null)

printf '# Auto-generated by mkosi.finalize from buildroot passwd/group\n' \
    | tee "$SYSUSERS_OUT" > "$TMPFILES_OUT"

# Emit g and u! lines, and tmpfiles d lines for /var homes
while IFS=: read -r name _ _ gid gecos home shell; do
    [ "$name" = "root" ] && continue
    echo "$SKIP_USERS" | grep -qxF "$name" && continue

    primary=$(awk -F: -v g="$gid" '$3==g {print $1; exit}' "$BUILDROOT/etc/group")
    echo "$SKIP_GROUPS" | grep -qxF "$primary" || \
        printf 'g %s -\n' "$primary" >> "$SYSUSERS_OUT"

    [ -z "$gecos" ] && gecos="-" || gecos="\"$gecos\""
    [ "$primary" = "$name" ] && id="-" || id="-:$primary"
    case "$home" in /var/*) ;; *) home="-" ;; esac
    case "$shell" in /sbin/nologin|/usr/sbin/nologin) shell="-" ;; esac

    printf 'u! %s %s %s %s %s\n' "$name" "$id" "$gecos" "$home" "$shell" >> "$SYSUSERS_OUT"

    if [ "$home" != "-" ] && [ ! -d "$BUILDROOT$home" ]; then
        printf 'd %s 0755 %s %s -\n' "$home" "$name" "$name" >> "$TMPFILES_OUT"
    fi

done < "$BUILDROOT/etc/passwd"

# Emit m lines for supplementary group memberships
while IFS=: read -r group _ _ members; do
    [ -z "$members" ] && continue

    printf '%s\n' "$members" | tr ',' '\n' | while IFS= read -r member; do
        [ -z "$member" ] && continue

        # user already has sysusers config
        echo "$SKIP_USERS" | grep -qxF "$member" && continue

        # root's supplementary memberships (from Alpine) are meaningless on a
        # systemd system, root's access is not gated by groups
        [ "$member" = "root" ] && continue

        # primary group membership is implicit from the u! line
        [ "$member" = "$group" ] && continue

        echo "$SKIP_MEMBERS" | grep -qxF "$member:$group" && continue
        printf 'm %s %s\n' "$member" "$group" >> "$SYSUSERS_OUT"
    done
done < "$BUILDROOT/etc/group"

# Build the base confext from /etc.
# NOTE: This next section *moves* /etc in the buildroot, so anything that
# follows this should not expect /etc to be populated!

# Remove machine-specific files that must not be in the confext
rm -f "$BUILDROOT/etc/machine-id" \
      "$BUILDROOT/etc/hostname" \
      "$BUILDROOT/etc/passwd-" \
      "$BUILDROOT/etc/group-" \
      "$BUILDROOT/etc/shadow-" \
      "$BUILDROOT/etc/gshadow-" \
      "$BUILDROOT/etc/.pwd.lock"

# Move /etc into the base confext image directory
mkdir -p "$BUILDROOT/usr/lib/confexts/duranium-base-config"
mv "$BUILDROOT/etc" "$BUILDROOT/usr/lib/confexts/duranium-base-config/etc"

# Generate extension-release
mkdir -p "$BUILDROOT/usr/lib/confexts/duranium-base-config/etc/extension-release.d"
# Extract ID from os-release to be sure it matches
OS_ID=$(grep '^ID=' "$BUILDROOT/usr/lib/os-release" | cut -d= -f2 | tr -d '"')
cat > "$BUILDROOT/usr/lib/confexts/duranium-base-config/etc/extension-release.d/extension-release.duranium-base-config" << EOF
ID=$OS_ID
CONFEXT_LEVEL=$IMAGE_VERSION
EOF

# Configure boot for UKI generation
if [ -d "$BUILDROOT/boot" ]; then
    # Find existing loader entry created by pmOS tooling
    EXISTING_ENTRY=$(find "$BUILDROOT/boot/loader/entries" -name "*.conf" -type f | head -1)

    if [ -f "$EXISTING_ENTRY" ]; then
        # Extract kernel, initrds, cmdline and DTB from existing entry
        KERNEL_FILE=""
        INITRD_FILES=""
        CMDLINE=""
        DTB_PATH=""

        while IFS= read -r line; do
            case "$line" in
                linux[[:space:]]*)
                    # Extract kernel filename
                    KERNEL_FILE=$(echo "$line" | sed 's/^linux[[:space:]]*//' | xargs basename)

                    # Move kernel to standard location for mkosi
                    # NOTE: Assumes only one kernel version directory exists...
                    for kdir in "$BUILDROOT"/usr/lib/modules/*/; do
                    [ -d "$kdir" ] && mv "$BUILDROOT/boot/$KERNEL_FILE" "$kdir/vmlinuz"
                        break
                    done
                    ;;
                initrd[[:space:]]*)
                    # Extract initrd filename and add to list
                    INITRD_FILE=$(echo "$line" | sed 's/^initrd[[:space:]]*//' | xargs basename)
                    INITRD_FILES="$INITRD_FILES $INITRD_FILE"
                    ;;
                devicetree[[:space:]]*)
                    # Extract DTB path
                    DTB_PATH=$(echo "$line" | sed 's/^devicetree[[:space:]]*//')
                    ;;
                options[[:space:]]*)
                    # Extract cmdline
                    CMDLINE=$(echo "$line" | sed 's/^options[[:space:]]*//')
                    ;;
            esac
        done < "$EXISTING_ENTRY"

        # Directory for kernel/UKI config
        mkdir -p "$BUILDROOT/etc/kernel"

        # Write cmdline file for mkosi
        if [ -n "$CMDLINE" ]; then
            echo "$CMDLINE" > "$BUILDROOT/etc/kernel/cmdline"
        fi

        # Write default number of tries for booting
        echo "3" > "$BUILDROOT/etc/kernel/tries"

        # Handle DTBs for device detection and UKI embedding
        if [ -n "$DTB_PATH" ]; then
            # Explicit DTB - keep only this one in /boot/dtbs/
            DTB_BASENAME=$(basename "$DTB_PATH")

            # Source deviceinfo to get proper DTB path with vendor directory
            if [ -f "$BUILDROOT/usr/share/deviceinfo/deviceinfo" ]; then
                . "$BUILDROOT/usr/share/deviceinfo/deviceinfo"
            fi

            if [ -n "$deviceinfo_dtb" ]; then
                # Use deviceinfo path (e.g., "rockchip/rk3399-pinebook-pro")
                DTB_TARGET_DIR=$(dirname "/boot/dtbs/$deviceinfo_dtb")
                mkdir -p "$BUILDROOT/$DTB_TARGET_DIR"
                mv "$BUILDROOT/boot/$DTB_BASENAME" "$BUILDROOT/boot/dtbs/${deviceinfo_dtb}.dtb"
            else
                # No deviceinfo_dtb, just put in /boot/dtbs/
                echo "Warning: deviceinfo_dtb not set, placing DTB in /boot/dtbs/ without vendor directory"
                mkdir -p "$BUILDROOT/boot/dtbs"
                mv "$BUILDROOT/boot/$DTB_BASENAME" "$BUILDROOT/boot/dtbs/$DTB_BASENAME"
            fi
        elif ls "$BUILDROOT"/boot/dtbs-*/ >/dev/null 2>&1; then
                mkdir -p "$BUILDROOT/boot/dtbs"
                cp -r "$BUILDROOT"/boot/dtbs-*/* "$BUILDROOT/boot/dtbs/"
        fi

        # Organize initramfs and microcode for mkosi UKI generation
        mkdir -p "$ARTIFACTDIR/io.mkosi.initrd"

        # Process initrd files, separating microcode
        for initrd in $INITRD_FILES; do
            if [ -f "$BUILDROOT/boot/$initrd" ]; then
                case "$initrd" in
                    *ucode.img|*-ucode.cpio*)
                        # Microcode files - place in separate directory for mkosi
                        mkdir -p "$ARTIFACTDIR/io.mkosi.microcode"
                        mv "$BUILDROOT/boot/$initrd" "$ARTIFACTDIR/io.mkosi.microcode/$initrd"
                        ;;
                esac
            fi
        done

        # Clean up boot artifacts (but preserve structure needed for ESP)
        # Remove kernel
        [ -n "$KERNEL_FILE" ] && rm -f "$BUILDROOT/boot/$KERNEL_FILE"

        # Remove loader entries (UKI replaces these)
        rm -rf "$BUILDROOT/boot/loader/entries"

        # Remove systemd-boot, mkosi will re-install this later. This is kinda
        # dumb to do but it avoids changes to mkosi so it doesn't get stuck on
        # the file conflict when it installs the bootloader.
        rm -rf "$BUILDROOT/boot/efi/boot"

        # Remove other cruft added to the esp by packaging
        rm -rf "$BUILDROOT/boot/dtbs-"*
        rm -f "$BUILDROOT/boot/System.map"* "$BUILDROOT/boot/config-"*

        # Note: /boot/dtbs is preserved

    else
        echo "Error: No existing boot loader entry found in $BUILDROOT/boot/loader/entries/"
        exit 1
    fi
fi

# After all DTB processing above, copy to standard location for mkosi
for kdir in "$BUILDROOT"/usr/lib/modules/*/; do
    if [ -d "$kdir" ]; then
        # Copy all DTBs to standard location
        if [ -d "$BUILDROOT/boot/dtbs" ]; then
            mkdir -p "$kdir/dtb"
            cp -r "$BUILDROOT"/boot/dtbs/* "$kdir/dtb/"
        fi
        # FIXME: Assumes only one kernel version directory exists
        break
    fi
done
