#!/bin/bash
set -e

# Layer Bluefin system files and configuration
echo "Finalizing Bluefin integration..."

# Bluefin system files are automatically copied via ExtraSearchPaths
# This script can run post-build customizations

# Set up shell defaults
if [ -f /usr/share/fish/vendor_conf.d/bluefin.fish ]; then
    cp /usr/share/fish/vendor_conf.d/bluefin.fish /etc/fish/conf.d/ || true
fi

echo "Bluefin finalization complete!"
