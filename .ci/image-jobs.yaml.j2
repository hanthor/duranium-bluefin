---
# Generated image jobs for Duranium builds
# This file is generated by generate_image_jobs.py from image-jobs.yaml.j2

stages:
  - build-packages
  - prepare
  - build-image
  - deploy-image

variables:
  REMOTE_BASE: "{{ remote_base }}"

determine-version:
  stage: prepare
  tags:
    - osuosl
  environment: deploy
  image: alpine:edge
  resource_group: global-version
  before_script:
    - apk upgrade -a
    - apk add mkosi openssh-client
    - |
      mkdir -p "$HOME"/.ssh
      echo "$SSH_HOST_KEY" > "$HOME"/.ssh/known_hosts
      echo "$SSH_PRIVATE_KEY" > "$HOME"/.ssh/id_ed25519
      chmod 600 "$HOME"/.ssh/id_ed25519
  script:
    - .ci/determine-version.sh
  artifacts:
    paths:
      - mkosi.version

.mkosi-common:
  image: alpine:edge
  before_script:
    - apk upgrade -a
    - |
      apk add bash \
              curl \
              distribution-gpg-keys \
              git \
              merge-usr \
              mkosi \
              python3

    - |
      merge-usr >/dev/null 2>&1 || :

    # convert to pmOS
    - ln -sf /usr/share/distribution-gpg-keys/postmarketos/build.postmarketos.org.rsa.pub /etc/apk/keys
    - echo "http://mirror.postmarketos.org/postmarketos/extra-repos/systemd/main" >> /etc/apk/repositories
    - echo "http://mirror.postmarketos.org/postmarketos/main" >> /etc/apk/repositories
    - apk add postmarketos-base-systemd
    - apk add postmarketos-base

.build-common:
  extends: .mkosi-common
  environment: build-image

.deploy-common:
  image: alpine:edge
  environment: deploy
  before_script:
    - apk upgrade -a
    - apk add gnupg openssh-client rsync
    - |
      mkdir -p "$HOME"/.ssh
      echo "$SSH_HOST_KEY" > "$HOME"/.ssh/known_hosts
      echo "$SSH_PRIVATE_KEY" > "$HOME"/.ssh/id_ed25519
      chmod 600 "$HOME"/.ssh/id_ed25519
    - gpg --import "$SYSUPDATE_PRIVATE_KEY"

{% for arch, combos in image_combos.items() %}
snapshot-repos-{{ arch }}:
  stage: prepare
  extends: .mkosi-common
  tags:
    - osuosl
    - {{ arch if arch in runner_archs else "x86_64" }}
{% if branch == "staging" %}
  needs:
    - build-packages-{{ arch }}
{% endif %}
  script:
{% if branch == "staging" %}
    - mkdir -p custom-repo
    - find packages -name '*.apk' -exec cp {} custom-repo/ \;
{% endif %}

    - apk add abuild openssl

    # NOTE: This is a requirement for snapshot-repos.py. By doing this setup
    # here, we avoid dozens of lines of python code doing the same thing
    - apk add --arch "$ARCH" --initdb --root simroot
    - cp -a /etc/apk/keys simroot/etc/apk/
    # Also cp keys for target arch or else apk will fail later the signing check
    # later for packages for that arch
    - cp /usr/share/apk/keys/$ARCH/* simroot/etc/apk/keys/
    - |
{% set release = combos[0].release %}
{% set subdir = "main" if release == "edge" else "v" + release %}
      echo "https://dl-cdn.alpinelinux.org/alpine/{{ release }}/main" > simroot/etc/apk/repositories
      echo "https://dl-cdn.alpinelinux.org/alpine/{{ release }}/community" >> simroot/etc/apk/repositories
{% if release == "edge" %}
      echo "https://dl-cdn.alpinelinux.org/alpine/{{ release }}/testing" >> simroot/etc/apk/repositories
{% endif %}
      echo "https://mirror.postmarketos.org/postmarketos/extra-repos/systemd/{{ subdir }}" >> simroot/etc/apk/repositories
      echo "https://mirror.postmarketos.org/postmarketos/{{ subdir }}" >> simroot/etc/apk/repositories
    - apk update --root simroot

    - ./.ci/snapshot-repos.py

    - openssl genrsa -out snapshot@local.rsa 4096
    - mkdir -p packages/keys
    - openssl rsa -in snapshot@local.rsa -pubout -out packages/keys/snapshot@local.rsa.pub
    - abuild-sign -k "$PWD/snapshot@local.rsa" packages/$ARCH/APKINDEX.tar.gz

  artifacts:
    expire_in: 1 day
    paths:
      - packages/
  variables:
    ARCH: "{{ arch }}"
    COMBOS: '{{ {"image": combos} | tojson }}'

{% if branch == "staging" %}
build-packages-{{ arch }}:
  stage: build-packages
  image: alpine:edge
  tags:
    - osuosl
    - {{ arch if arch in runner_archs else "x86_64" }}
  before_script:
    - apk upgrade -a
    - apk add curl
    - "echo '140.211.167.182 gitlab.postmarketos.org' >> /etc/hosts"
    - curl -4fsSL "https://gitlab.postmarketos.org/postmarketOS/ci-common/-/raw/main/install_pmbootstrap.sh" | sh
    - su pmos -c "cd ~/.local/var/pmbootstrap/cache_git/pmaports && git checkout duranium/staging"
  script:
    - su pmos -c "cd ~/.local/var/pmbootstrap/cache_git/pmaports && ./.ci/build-{{ arch }}.sh"
    - mkdir -p packages
    - |
      if [ -d /home/pmos/.local/var/pmbootstrap/packages ]; then
        find /home/pmos/.local/var/pmbootstrap/packages -name "*.apk" -exec cp {} packages/ \;
      fi
  artifacts:
    expire_in: 1 day
    paths:
      - packages/
  variables:
    ARCH: "{{ arch }}"
{% endif %}

{% for combo in combos %}
build-image-{{ combo.device }}-{{ combo.ui }}-{{ combo.release }}:
  stage: build-image
  extends: .build-common
  tags:
    - osuosl
    - {{ arch if arch in runner_archs else "x86_64" }}
  needs:
    - determine-version
    - snapshot-repos-{{ arch }}
  script:
    # Register binfmt when building image for non-native arch
{% if arch not in runner_archs %}
    - apk add qemu-{{ arch }}
    - mount -t binfmt_misc binfmt_misc /proc/sys/fs/binfmt_misc || true
    - cat /usr/lib/binfmt.d/qemu-{{ arch }}.conf > /proc/sys/fs/binfmt_misc/register || true
{% endif %}

    # Install TEST keys for verity partition signing
    # FIXME: this is obviously not secure
    - cp "$MKOSI_KEY" mkosi.key
    - cp "$MKOSI_CRT" mkosi.crt
    - chmod 600 mkosi.key

    # make sure snapshot repo key is available in the sandbox
    - mkdir -p mkosi.sandbox/etc/apk/keys
    - mkdir -p mkosi.tools/etc/apk/keys
    - cp packages/keys/*.pub mkosi.sandbox/etc/apk/keys/
    - cp packages/keys/*.pub mkosi.tools/etc/apk/keys/

    # Generate image ID for this device+ui+release combo
    - export IMAGE_ID="${DEVICE}_${UI}_${RELEASE}"

    # Note: set workspace dir in /builds so that mkosi doesn't try to work
    # across multiple devices (e.g. / which is overlayfs)
    - |
      ./scripts/build-image.py device-$DEVICE ui-$UI \
        --local-mirror=file://$(pwd)/packages \
        --release=$RELEASE \
        --workspace-directory=/builds/mkosi-workspace \
        --cache-only=always \
        --profile=compressed

    - |
      cd mkosi.output/$IMAGE_ID
      # There's no reason to keep the split ESP dir or separate initrd artifact
      # that mkosi creates
      rm -f ${IMAGE_ID}_*.esp.* || true
      rm -f initrd* || true
      sha256sum ${IMAGE_ID}_*.raw.zst ${IMAGE_ID}_*.efi > SHA256SUMS

  artifacts:
    expire_in: 3 hours
    paths:
      - mkosi.output/*/*.raw.zst
      - mkosi.output/*/*.efi
      - mkosi.output/*/SHA256SUMS
      - mkosi.version
  variables:
    ARCH: "{{ arch }}"
    DEVICE: "{{ combo.device }}"
    UI: "{{ combo.ui }}"
    RELEASE: "{{ combo.release }}"

deploy-image-{{ combo.device }}-{{ combo.ui }}-{{ combo.release }}:
  stage: deploy-image
  extends: .deploy-common
  tags:
    - osuosl
  resource_group: manifest-{{ combo.device }}-{{ combo.ui }}-{{ combo.release }}
  needs:
    - build-image-{{ combo.device }}-{{ combo.ui }}-{{ combo.release }}

  script:
    - .ci/deploy-image.sh
  variables:
    ARTIFACT_PREFIX: "{{ combo.device }}_{{ combo.ui }}_{{ combo.release }}"
    DEPLOY_DIR: "{{ combo.device }}_{{ combo.ui }}_{{ combo.release }}"
    DEVICE: "{{ combo.device }}"
    RELEASE: "{{ combo.release }}"
    UI: "{{ combo.ui }}"

{% endfor %}
{% endfor %}
